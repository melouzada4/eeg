def canal_pertence_regiao_ampla(nome_canal, prefixo):
    """Retorna True se o canal pertence à região ampla (pelo prefixo da letra)."""
    return nome_canal.upper().startswith(prefixo.upper())


def canal_pertence_regiao_especifica(nome_canal, lista_canais):
    """Retorna True se o canal está na lista específica (case-insensitive)."""
    return nome_canal.upper() in [c.upper() for c in lista_canais]


# ============================================================
# Extrai prefixo canônico  ex: "50_T0"
# ============================================================

def extrair_prefixo(nome: str) -> str:
    m = re.search(r'(\d+_T\d+)', nome, re.IGNORECASE)
    if m:
        return m.group(1).upper()
    return nome.strip().lower()


