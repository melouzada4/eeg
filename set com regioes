            plt.Line2D([0],[0], color='#000000', linewidth=1.5,                label='Original Spectrum'),
            plt.Line2D([0],[0], color='#e74c3c', linewidth=2,                 label='Full FOOOF Model'),
            plt.Line2D([0],[0], color='#3498db', linewidth=2, linestyle='--', label='Aperiodic Component'),
            plt.Line2D([0],[0], color='#2ecc71', linewidth=2,                 label='Periodic Component (Gaussians)'),
        ]
        legend = plt.legend(handles=handles, loc='center right', bbox_to_anchor=(0.99, 0.5),
                            fontsize=9, frameon=True, fancybox=True, shadow=True, framealpha=0.9)
        legend.get_frame().set_facecolor('white')
        legend.get_frame().set_edgecolor('black')
        plt.grid(True, linestyle='--', linewidth=0.5, alpha=0.3, color='gray')

        ax           = plt.gca()
        psd_med_per  = np.mean(componente_periodica)
        area_per     = np.trapezoid(componente_periodica, freq_banda)
        picos_brutos = resultado.get('picos_brutos', resultado.get('picos', []))
        n_picos      = len(picos_brutos)

        stats_text = (
            f"Estatísticas {nome_banda.upper()} ({fmin:.1f}-{fmax} Hz):\n"
            f"[FOOOF fit: {FOOOF_FMIN:.0f}-{FOOOF_FMAX:.0f} Hz]\n"
            f"[Média: geométrica (log-espaço)]\n\n"
            f"ORIGINAL (potência padrão EEG):\n"
            f"PSD Média: {np.mean(psd_banda_micro):.4f} µV²/Hz\n"
            f"Área: {np.trapezoid(psd_banda_micro, freq_banda):.4f} µV²\n\n"
            f"APERIÓDICA:\n"
            f"PSD Média: {np.mean(ap_fit_linear):.4f} µV²/Hz\n"
            f"Área: {np.trapezoid(ap_fit_linear, freq_banda):.4f} µV²\n\n"
            f"PERIÓDICA (gaussianas FOOOF):\n"
            f"PSD Média: {psd_med_per:.4f} µV²/Hz\n"
            f"Área: {area_per:.4f} µV²\n"
            f"  ⚠ Não equivale à potência total da banda\n\n"
        )
        if picos_brutos:
            stats_text += (f"Picos ({n_picos}):\n"
                           f"Freq. Média: {np.mean([p['frequencia'] for p in picos_brutos]):.2f} Hz\n"
                           f"PSD Média: {np.mean([p['psd_fit'] for p in picos_brutos]):.4f} µV²/Hz")
        else:
            stats_text += "Picos: Nenhum detectado"

        plt.text(0.98, 0.98, stats_text, transform=ax.transAxes, fontsize=8,
                 verticalalignment='top', horizontalalignment='right',
                 bbox=dict(boxstyle='round,pad=0.5', facecolor='white', edgecolor='black', alpha=0.9))
        plt.text(0.02, 0.02,
                 f"FOOOF ({FOOOF_FMIN:.0f}-{FOOOF_FMAX:.0f} Hz):\nR²: {resultado.get('r_squared',0):.4f}\nPicos: {n_picos}",
                 transform=ax.transAxes, fontsize=9, verticalalignment='bottom', horizontalalignment='left',
                 bbox=dict(boxstyle='round,pad=0.4', facecolor='lightblue', edgecolor='black', alpha=0.9))

        plt.tight_layout()
        sufixo    = "_MEDIA" if 'n_intervalos' in resultado else ""
        nome_graf = f"{prefixo_arquivo}_{nome_canal}_{nome_banda}_{condicao}_FOOOF{sufixo}.png"
        plt.savefig(os.path.join(pasta_saida, nome_graf), dpi=300, bbox_inches='tight',
                    facecolor='white', edgecolor='none')
        plt.close()
        print(f"        Gráfico salvo: {nome_graf}")

    except Exception as e:
        print(f"        Erro ao criar gráfico: {e}")
        plt.close()


# ============================================================
# MODIFICAÇÃO 1: calcular_media_metricas agora inclui
#   - desvio padrão da frequência média dos picos
#   - desvio padrão do PSD dos picos
#   - desvio padrão do PSD periódico
# Retorna também as listas brutas para uso posterior nas médias regionais
# ============================================================

def calcular_media_metricas(lista_resultados):
    validos = [r for r in lista_resultados if r is not None]
    if not validos:
        return None

    n      = len(validos)
    campos = ['psd_media_original', 'area_original', 'psd_media_aperiodic',
              'area_aperiodic', 'psd_media_fit', 'area_fit', 'r_squared', 'erro']
    soma   = {c: 0   for c in campos}
    listas = {c: []  for c in campos}
    todos_picos = []

    for r in validos:
        for c in campos:
            soma[c] += r[c]
            listas[c].append(r[c])
        todos_picos.extend(r.get('picos', []))

    media = {
        'num_intervalos_validos': n,
        **{c: soma[c] / n              for c in campos},
        **{f'{c}_std': np.std(listas[c]) for c in campos},
    }

    # ── PICOS: frequência e PSD com desvio padrão ──────────────────────────
    if todos_picos:
        freqs_picos = [p['frequencia'] for p in todos_picos]
        psd_picos   = [p['psd_fit']    for p in todos_picos]
        media.update({
            'num_picos_total':            len(todos_picos),
            # Frequência dos picos
            'frequencia_picos_media':     np.mean(freqs_picos),
            'frequencia_picos_std':       np.std(freqs_picos),   # ← NOVO: DP da freq dos picos
            'frequencia_picos_min':       np.min(freqs_picos),
            'frequencia_picos_max':       np.max(freqs_picos),
            # PSD dos picos
            'psd_fit_picos_media':        np.mean(psd_picos),
            'psd_fit_picos_std':          np.std(psd_picos),     # ← NOVO: DP do PSD dos picos
            # PSD periódico (já tem média via campo psd_media_fit, aqui o DP extra)
            'psd_periodica_media':        media['psd_media_fit'],
            'psd_periodica_std':          media['psd_media_fit_std'],
        })
    else:
        media.update({
            'num_picos_total':        0,
            'frequencia_picos_media': None,
            'frequencia_picos_std':   None,
            'frequencia_picos_min':   None,
            'frequencia_picos_max':   None,
            'psd_fit_picos_media':    None,
            'psd_fit_picos_std':      None,
            'psd_periodica_media':    media['psd_media_fit'],
            'psd_periodica_std':      media['psd_media_fit_std'],
        })

    # Guarda lista de picos brutos para uso nas médias regionais
    media['_picos_brutos'] = todos_picos
    return media


# ============================================================
# MODIFICAÇÃO 2 e 3: médias por região e região específica
#
# acumula_dados_regionais() — chamado a cada canal processado
# calcular_e_salvar_medias_regionais() — chamado ao final
# ============================================================

def _prefixo_regiao_ampla(nome_canal):
    """Retorna a chave da região ampla à qual o canal pertence, ou None."""
    ch_up = nome_canal.upper()
    for regiao, prefixo in REGIOES_AMPLAS_PREFIXOS.items():
        if ch_up.startswith(prefixo.upper()):
            return regiao
    return None


def _regiao_especifica(nome_canal):
    """Retorna a chave da região específica à qual o canal pertence, ou None."""
    ch_up = nome_canal.upper()
    for regiao, lista in REGIOES_ESPECIFICAS.items():
        if ch_up in [c.upper() for c in lista]:
            return regiao
    return None


def acumula_dados_regionais(banco_regional, nome_canal, nome_banda, condicao, media_metricas):
    """
    Acumula médias de canais no banco regional para posterior cálculo.

    banco_regional: dict estruturado como
      banco_regional[tipo_regiao][nome_regiao][banda][condicao] = lista de dicts
    onde cada dict tem as métricas do canal (média dos intervalos).
    """
    if media_metricas is None:
        return

    regiao_ampla   = _prefixo_regiao_ampla(nome_canal)
    regiao_espec   = _regiao_especifica(nome_canal)

    # Prepara entrada com as métricas relevantes deste canal
    entrada = {
        'canal':               nome_canal,
        'psd_periodica_media': media_metricas.get('psd_media_fit'),
        'psd_periodica_std':   media_metricas.get('psd_media_fit_std'),
        'psd_pico_media':      media_metricas.get('psd_fit_picos_media'),
        'psd_pico_std':        media_metricas.get('psd_fit_picos_std'),
        'freq_pico_media':     media_metricas.get('frequencia_picos_media'),
        'freq_pico_std':       media_metricas.get('frequencia_picos_std'),
        'num_picos':           media_metricas.get('num_picos_total', 0),
        'num_intervalos':      media_metricas.get('num_intervalos_validos', 0),
        '_picos_brutos':       media_metricas.get('_picos_brutos', []),
    }

    chave_cond = condicao   # 'OA' ou 'OF'

    if regiao_ampla:
        (banco_regional
            .setdefault('ampla', {})
            .setdefault(regiao_ampla, {})
            .setdefault(nome_banda, {})
            .setdefault(chave_cond, [])
            .append(entrada))

    if regiao_espec:
        (banco_regional
            .setdefault('especifica', {})
            .setdefault(regiao_espec, {})
            .setdefault(nome_banda, {})
            .setdefault(chave_cond, [])
            .append(entrada))


def _resumo_regional(entradas):
    """
    Dado uma lista de entradas (dicts) de canais de uma mesma região/banda/condição,
    calcula médias e DPs das métricas principais.
    Retorna dict com o resumo ou None se não houver dados.
    """
    if not entradas:
        return None

    canais = [e['canal'] for e in entradas]

    # PSD Periódica: média dos valores médios de cada canal
    vals_psd_per = [e['psd_periodica_media'] for e in entradas if e['psd_periodica_media'] is not None]

    # PSD do Pico: média dos valores médios de cada canal
    vals_psd_pico = [e['psd_pico_media'] for e in entradas if e['psd_pico_media'] is not None]

    # Frequência do Pico: coleta TODOS os picos brutos de todos os canais da região
    # para calcular média e DP sobre os picos individuais (não sobre médias de canais)
    todos_picos_brutos = []
    for e in entradas:
        todos_picos_brutos.extend(e.get('_picos_brutos', []))

    freqs_picos_brutos = [p['frequencia'] for p in todos_picos_brutos]
    psd_picos_brutos   = [p['psd_fit']    for p in todos_picos_brutos]

    resumo = {
        'canais':          canais,
        'n_canais':        len(canais),
        'n_picos_total':   len(todos_picos_brutos),

        # PSD Periódica (média entre canais da região)
        'psd_periodica_media': np.mean(vals_psd_per)  if vals_psd_per  else None,
        'psd_periodica_std':   np.std(vals_psd_per)   if len(vals_psd_per) > 1  else (0.0 if vals_psd_per else None),

        # PSD do Pico (média entre canais da região)
        'psd_pico_media': np.mean(vals_psd_pico) if vals_psd_pico else None,
        'psd_pico_std':   np.std(vals_psd_pico)  if len(vals_psd_pico) > 1 else (0.0 if vals_psd_pico else None),

        # Frequência dos Picos — calculada sobre TODOS os picos brutos da região
        'freq_pico_media': np.mean(freqs_picos_brutos) if freqs_picos_brutos else None,
        'freq_pico_std':   np.std(freqs_picos_brutos)  if len(freqs_picos_brutos) > 1 else (0.0 if freqs_picos_brutos else None),
        'freq_pico_min':   np.min(freqs_picos_brutos)  if freqs_picos_brutos else None,
        'freq_pico_max':   np.max(freqs_picos_brutos)  if freqs_picos_brutos else None,

        # PSD picos brutos (para conferência)
        'psd_pico_bruto_media': np.mean(psd_picos_brutos) if psd_picos_brutos else None,
        'psd_pico_bruto_std':   np.std(psd_picos_brutos)  if len(psd_picos_brutos) > 1 else (0.0 if psd_picos_brutos else None),
    }
    return resumo


def calcular_e_salvar_medias_regionais(banco_regional, prefixo, pasta_saida):
    """
    Processa o banco_regional acumulado e salva um arquivo de texto
    com as médias e DPs por região (ampla e específica), banda e condição.
    """
    caminho = os.path.join(pasta_saida, f"{prefixo}_MEDIAS_REGIONAIS.txt")

    def formatar_val(v, decimais=5):
        return f"{v:.{decimais}f}" if v is not None else "N/A"

    def bloco_regiao(nome_regiao, entradas_por_banda_cond, tipo_label):
        linhas = [f"\n  {'─'*60}",
                  f"  {tipo_label}: {nome_regiao}",
                  f"  {'─'*60}"]

        for banda in sorted(entradas_por_banda_cond.keys()):
            linhas.append(f"\n    Banda: {banda.upper()}")
            for cond in ['OA', 'OF']:
                cond_nome = "Olhos Abertos" if cond == "OA" else "Olhos Fechados"
                entradas  = entradas_por_banda_cond[banda].get(cond, [])
                res       = _resumo_regional(entradas)

                linhas.append(f"\n      {cond_nome} ({cond}):")
                if res is None or res['n_canais'] == 0:
                    linhas.append("        Sem dados para esta região/condição.")
                    continue

                linhas.append(f"        Canais incluídos ({res['n_canais']}): {', '.join(res['canais'])}")
                linhas.append(f"        Total de picos brutos: {res['n_picos_total']}")
                linhas.append("")
                linhas.append(f"        PSD Periódica (µV²/Hz):")
                linhas.append(f"          Média: {formatar_val(res['psd_periodica_media'])}  ±  {formatar_val(res['psd_periodica_std'])} (DP)")
                linhas.append("")
                linhas.append(f"        PSD do Pico (µV²/Hz):")
                linhas.append(f"          Média (por canal): {formatar_val(res['psd_pico_media'])}  ±  {formatar_val(res['psd_pico_std'])} (DP)")
                linhas.append(f"          Média (picos brutos): {formatar_val(res['psd_pico_bruto_media'])}  ±  {formatar_val(res['psd_pico_bruto_std'])} (DP)")
                linhas.append("")
                linhas.append(f"        Frequência dos Picos (Hz)  [calculada sobre todos os picos brutos da região]:")
                linhas.append(f"          Média: {formatar_val(res['freq_pico_media'], 3)}  ±  {formatar_val(res['freq_pico_std'], 3)} (DP)")
                linhas.append(f"          Mín: {formatar_val(res['freq_pico_min'], 3)}   Máx: {formatar_val(res['freq_pico_max'], 3)}")

        return linhas

    with open(caminho, 'w', encoding='utf-8') as f:
        f.write(f"MÉDIAS REGIONAIS — {prefixo}\n")
        f.write(f"R² threshold: {R2_THRESHOLD}  |  FOOOF fit: {FOOOF_FMIN:.0f}-{FOOOF_FMAX:.0f} Hz\n")
        f.write(f"Componente periódica: gaussianas FOOOF (Donoghue et al., 2020)\n")
        f.write("=" * 80 + "\n")
        f.write("\nNOTAS METODOLÓGICAS:\n")
        f.write("  • PSD Periódica: média (e DP) calculada sobre as médias dos canais da região.\n")
        f.write("  • PSD do Pico (por canal): média/DP das médias de pico de cada canal.\n")
        f.write("  • PSD do Pico (picos brutos): média/DP de todos os picos individuais da região.\n")
        f.write("  • Freq. dos Picos: média/DP calculada sobre TODOS os picos brutos da região\n")
        f.write("    (não sobre médias de canal), capturando variabilidade real dos picos.\n")
        f.write("=" * 80 + "\n")

        # ── Regiões Amplas ───────────────────────────────────────────────────
        f.write("\n\n╔══════════════════════════════════════════════════════════════╗\n")
        f.write(  "║  1. REGIÕES AMPLAS                                           ║\n")
        f.write(  "║  (todos os canais com o mesmo prefixo de letra)              ║\n")
        f.write(  "╚══════════════════════════════════════════════════════════════╝\n")
        f.write(  "  Frontal: todos F* | Parietal: todos P* | Occipital: todos O* | Temporal: todos T*\n")

        amplas = banco_regional.get('ampla', {})
        for nome_regiao in ['Frontal', 'Parietal', 'Occipital', 'Temporal']:
            dados_regiao = amplas.get(nome_regiao, {})
            linhas = bloco_regiao(nome_regiao, dados_regiao, "REGIÃO AMPLA")
            f.write('\n'.join(linhas) + '\n')

        # ── Regiões Específicas ──────────────────────────────────────────────
        f.write("\n\n╔══════════════════════════════════════════════════════════════╗\n")
        f.write(  "║  2. REGIÕES ESPECÍFICAS                                      ║\n")
        f.write(  "╚══════════════════════════════════════════════════════════════╝\n")
        labels_espec = {
            'F_especifico': 'F3, F4, Fz',
            'P_especifico': 'P3, P4, Pz',
            'O_especifico': 'O1, O2, Oz',
        }
        especificas = banco_regional.get('especifica', {})
        for nome_regiao, canais_label in labels_espec.items():
            dados_regiao = especificas.get(nome_regiao, {})
            linhas = bloco_regiao(f"{nome_regiao.replace('_especifico','')} específico ({canais_label})",
                                  dados_regiao, "REGIÃO ESPECÍFICA")
            f.write('\n'.join(linhas) + '\n')

        f.write("\n" + "=" * 80 + "\n")
        f.write("FIM DO RELATÓRIO DE MÉDIAS REGIONAIS\n")

    print(f"\n  🗺️  Médias regionais salvas: {prefixo}_MEDIAS_REGIONAIS.txt")
    return caminho


