def _boundary_samples(raw):
    b_samps = []
    ann = getattr(raw, 'annotations', None)
    if ann is None or len(ann) == 0:
        return b_samps
    for desc, onset, dur in zip(ann.description, ann.onset, ann.duration):
        if isinstance(desc, str) and 'boundary' in desc.lower():
            b_samps.append(raw.time_as_index(onset)[0])
    return sorted(set(b_samps))


def _contiguous_segments(n_samples, boundary_idxs, min_len):
    if not boundary_idxs:
        return [(0, n_samples)]
    segs, last = [], 0
    for b in boundary_idxs:
        if b - last >= min_len:
            segs.append((last, b))
        last = b
    if n_samples - last >= min_len:
        segs.append((last, n_samples))
    return segs


def welch_discontinuous(signal, fs, nperseg, noverlap, nfft, segments):
    sum_psd, sum_weights, freqs_ref = None, 0.0, None
    step = nperseg - noverlap

    for (s0, s1) in segments:
        seg = signal[s0:s1]
        if seg.size < nperseg:
            continue
        f_seg, pxx_seg = welch(seg, fs=fs, nperseg=nperseg, noverlap=noverlap, nfft=nfft)
        nwin = max(int(1 + (seg.size - nperseg) // step), 1)

        if freqs_ref is None:
            freqs_ref = f_seg
            sum_psd   = pxx_seg * nwin
        else:
            if len(f_seg) != len(freqs_ref) or not np.allclose(f_seg, freqs_ref):
                pxx_seg = np.interp(freqs_ref, f_seg, pxx_seg)
            sum_psd += pxx_seg * nwin
        sum_weights += nwin

    if sum_psd is None or sum_weights == 0:
        return None, None
    return freqs_ref, sum_psd / sum_weights


def extrair_segmento_temporal(dados_completos, srate, inicio_seg, duracao_seg):
    s0 = max(int(inicio_seg * srate), 0)
    s1 = min(int((inicio_seg + duracao_seg) * srate), dados_completos.shape[1])
    return dados_completos[:, s0:s1]


# ============================================================
# Reconstrução da componente periódica via gaussianas FOOOF
# ============================================================

def reconstruir_componente_periodica(fm, freqs):
    comp_log = np.zeros_like(freqs, dtype=float)

    if hasattr(fm, 'gaussian_params_') and fm.gaussian_params_ is not None and len(fm.gaussian_params_) > 0:
        for cf, amp, bw in fm.gaussian_params_:
            comp_log += amp * np.exp(-((freqs - cf) ** 2) / (2 * bw ** 2))

    comp_linear = 10 ** comp_log - 1.0
    comp_linear = np.maximum(comp_linear, 0.0)
    return comp_linear


# ============================================================
# Média de PSD em log-espaço entre intervalos
# ============================================================

def media_psd_log(lista_psd_arrays):
    validos = [a for a in lista_psd_arrays if a is not None and np.all(np.isfinite(a)) and np.all(a > 0)]
    if not validos:
        return None
    log_arrays = [np.log10(a) for a in validos]
    media_log  = np.mean(np.stack(log_arrays, axis=0), axis=0)
    return 10 ** media_log, len(validos)


# ============================================================
# FOOOF — threshold unificado em R2_THRESHOLD
# ============================================================

def calcular_metricas_fooof_segmento(dados_segmento_canal, srate, nome_banda, fmin_banda, fmax_banda):
    try:
        if dados_segmento_canal.size == 0:
            return None, "segmento vazio"
        if np.all(dados_segmento_canal == 0):
            return None, "sinal zerado"

        nperseg = int(srate * 2)
        if nperseg > dados_segmento_canal.shape[0]:
            nperseg = dados_segmento_canal.shape[0]
        noverlap = int(nperseg * 0.5)
        nfft     = int(srate * 8)

        freqs_full, psd_full = welch_discontinuous(
            dados_segmento_canal, fs=srate,
            nperseg=nperseg, noverlap=noverlap, nfft=nfft,
            segments=[(0, dados_segmento_canal.shape[0])]
        )
        if freqs_full is None:
            return None, "Welch falhou (segmento curto demais)"

        psd_full_uv2 = psd_full

        idx_ampla = (freqs_full >= FOOOF_FMIN) & (freqs_full <= FOOOF_FMAX)
        if np.sum(idx_ampla) < 10:
            return None, f"poucos pontos na faixa {FOOOF_FMIN}-{FOOOF_FMAX}Hz ({np.sum(idx_ampla)} pontos)"

        freq_ampla = freqs_full[idx_ampla]
        psd_ampla  = psd_full_uv2[idx_ampla]

        if np.any(psd_ampla <= 0):
            return None, "PSD contém valores <= 0"
        if np.any(np.isnan(psd_ampla)) or np.any(np.isinf(psd_ampla)):
            return None, "PSD contém NaN ou Inf"

        fm = FOOOF(**fooof_config)
        fm.fit(freq_ampla, psd_ampla)

        r2 = fm.r_squared_
        if r2 < R2_THRESHOLD:
            return None, f"R²={r2:.4f} abaixo do threshold ({R2_THRESHOLD})"

        ap_fit_ampla = (10 ** fm._ap_fit) if hasattr(fm, '_ap_fit') and fm._ap_fit is not None \
                       else np.ones_like(psd_ampla)

        comp_per_excesso_ampla = reconstruir_componente_periodica(fm, freq_ampla)
        comp_per_ampla_uv2 = comp_per_excesso_ampla * ap_fit_ampla

        idx_banda = (freq_ampla >= fmin_banda) & (freq_ampla <= fmax_banda)
        if np.sum(idx_banda) < 5:
            return None, f"poucos pontos na banda {nome_banda} ({np.sum(idx_banda)} pontos)"

        freq_banda           = freq_ampla[idx_banda]
        psd_banda_uv2        = psd_ampla[idx_banda]
        ap_fit_banda         = ap_fit_ampla[idx_banda]
        comp_per_banda_uv2   = comp_per_ampla_uv2[idx_banda]

        full_fit_ampla  = ap_fit_ampla + comp_per_ampla_uv2
        full_fit_banda  = ap_fit_banda  + comp_per_banda_uv2

        offset   = fm.aperiodic_params_[0] if hasattr(fm, 'aperiodic_params_') and len(fm.aperiodic_params_) >= 1 else None
        expoente = fm.aperiodic_params_[1] if hasattr(fm, 'aperiodic_params_') and len(fm.aperiodic_params_) >= 2 else None

        from scipy.signal import find_peaks
        picos_info = []
        if hasattr(fm, 'peak_params_') and fm.peak_params_ is not None and len(fm.peak_params_) > 0:
            for freq_pico_fooof, amp_pico, bw_pico in fm.peak_params_:
                if not (fmin_banda <= freq_pico_fooof <= fmax_banda):
                    continue
                idx_aprox  = np.argmin(np.abs(freq_banda - freq_pico_fooof))
                janela_hz  = max(bw_pico, 1.0)
                idx_janela = (freq_banda >= freq_pico_fooof - janela_hz / 2) & \
                             (freq_banda <= freq_pico_fooof + janela_hz / 2)

                if np.sum(idx_janela) < 3:
                    idx_pico_real = idx_aprox
                else:
                    periodica_janela = comp_per_banda_uv2[idx_janela]
                    picos_locais, _  = find_peaks(periodica_janela, height=0)
                    indices_janela   = np.where(idx_janela)[0]
                    if len(picos_locais) > 0:
                        idx_pico_real = indices_janela[picos_locais[np.argmax(periodica_janela[picos_locais])]]
                    else:
                        idx_pico_real = indices_janela[np.argmax(periodica_janela)]

                freq_pico_visual = freq_banda[idx_pico_real]
                psd_fit_pico     = comp_per_banda_uv2[idx_pico_real]

                if abs(freq_pico_visual - freq_pico_fooof) > 2 * bw_pico:
                    idx_pico_real    = idx_aprox
                    freq_pico_visual = freq_banda[idx_aprox]
                    psd_fit_pico     = comp_per_banda_uv2[idx_aprox]

                picos_info.append({
                    'frequencia':             freq_pico_visual,
                    'frequencia_fooof':       freq_pico_fooof,
                    'amplitude':              amp_pico,
                    'largura':                bw_pico,
                    'psd_fit':                psd_fit_pico,
                    'densidade_original':     psd_banda_uv2[idx_pico_real],
                    'densidade_fit':          psd_fit_pico,
                    'densidade_aperiodic':    ap_fit_banda[idx_pico_real],
                    'densidade_isolada':      psd_fit_pico,
                    'potencia_fit':           psd_fit_pico,
                    'indice_freq':            idx_pico_real,
                    'diferenca_fooof_visual': abs(freq_pico_visual - freq_pico_fooof),
                })

        area_original  = np.trapezoid(psd_banda_uv2,       freq_banda)
        area_aperiodic = np.trapezoid(ap_fit_banda,          freq_banda)
        area_periodica = np.trapezoid(comp_per_banda_uv2,    freq_banda)

        return {
            'psd_media_original':      np.mean(psd_banda_uv2),
            'desvio_padrao_original':  np.std(psd_banda_uv2),
            'area_original':           area_original,

            'psd_media_aperiodic':     np.mean(ap_fit_banda),
            'desvio_padrao_aperiodic': np.std(ap_fit_banda),
            'area_aperiodic':          area_aperiodic,

            'psd_media_fit':           np.mean(comp_per_banda_uv2),
            'desvio_padrao_fit':       np.std(comp_per_banda_uv2),
            'area_fit':                area_periodica,

            'picos':                   picos_info,
            'r_squared':               fm.r_squared_,
            'erro':                    fm.error_,
            'expoente_aperiodico':     expoente,
            'offset_aperiodico':       offset,

            'potencia_total_area':     area_periodica,
            'densidade_media':         np.mean(comp_per_banda_uv2),
            'desvio_padrao':           np.std(comp_per_banda_uv2),
            'area_psd':                area_periodica,
            'potencia_total':          area_periodica,
            'densidade_max':           np.max(comp_per_banda_uv2),
            'potencia_media':          np.mean(comp_per_banda_uv2),
            'potencia_max':            np.max(comp_per_banda_uv2),
            'fooof_model':             fm,

            'freq_banda':              freq_banda,
            'psd_banda_micro':         psd_banda_uv2,
            'psd_banda_linear':        psd_ampla[idx_banda],
            'full_fit_linear':         full_fit_banda,
            'ap_fit_linear':           ap_fit_banda,
            'componente_periodica':    comp_per_banda_uv2,
            'freq_ampla':              freq_ampla,
            'psd_ampla_micro':         psd_ampla,
            'full_fit_ampla':          full_fit_ampla,
            'ap_fit_ampla':            ap_fit_ampla,
            'componente_periodica_ampla': comp_per_ampla_uv2,
        }, None

    except Exception as e:
        return None, f"exceção: {e}"


# ============================================================
# Médias e gráficos
# ============================================================

def calcular_media_fooof_para_grafico(lista_metricas):
    metricas_validas = [m for m in lista_metricas if m is not None]
    if not metricas_validas:
        return None

    freq_banda_ref = metricas_validas[0]['freq_banda']
    n_freq         = len(freq_banda_ref)

    todos_picos = []
    psd_arrays  = []
    fit_arrays  = []
    ap_arrays   = []
    per_arrays  = []

    for m in metricas_validas:
        arrays = [m['psd_banda_micro'], m['full_fit_linear'], m['ap_fit_linear'], m['componente_periodica']]
        if any(np.any(np.isnan(a)) or np.any(np.isinf(a)) for a in arrays):
            print("      Aviso: intervalo ignorado na média do gráfico (NaN/Inf)")
            continue
        if len(m['freq_banda']) == n_freq and np.allclose(m['freq_banda'], freq_banda_ref):
            psd_arrays.append(m['psd_banda_micro'])
            fit_arrays.append(m['full_fit_linear'])
            ap_arrays.append(m['ap_fit_linear'])
            per_arrays.append(m['componente_periodica'])
            todos_picos.extend(m.get('picos', []))

    if not psd_arrays:
        return None

    n_usadas = len(psd_arrays)

    def _media_geo(arrays):
        validos = [a for a in arrays if np.all(a > 0)]
        if not validos:
            return np.mean(np.stack(arrays, axis=0), axis=0)
        log_stack = np.log10(np.stack(validos, axis=0))
        return 10 ** np.mean(log_stack, axis=0)

    psd_media = _media_geo(psd_arrays)
    fit_media = _media_geo(fit_arrays)
    ap_media  = _media_geo(ap_arrays)
    per_media = np.mean(np.stack(per_arrays, axis=0), axis=0)

    class FooofMedio:
        def __init__(self):
            self.r_squared_   = np.mean([m['r_squared'] for m in metricas_validas])
            self.error_       = np.mean([m['erro']       for m in metricas_validas])
            self.peak_params_ = []
            if todos_picos:
                grupos = []
                for p in todos_picos:
                    adicionado = False
                    for g in grupos:
                        if abs(p['frequencia'] - g[0]['frequencia']) <= 1.0:
                            g.append(p); adicionado = True; break
                    if not adicionado:
                        grupos.append([p])
                for g in grupos:
                    self.peak_params_.append([
                        np.mean([p['frequencia'] for p in g]),
                        np.mean([p['amplitude']  for p in g]),
                        np.mean([p['largura']    for p in g]),
                    ])

    fm_medio     = FooofMedio()
    picos_medios = []
    for freq_p, amp_p, larg_p in fm_medio.peak_params_:
        idx_p = np.argmin(np.abs(freq_banda_ref - freq_p))
        picos_medios.append({
            'frequencia': freq_p, 'frequencia_fooof': freq_p,
            'amplitude': amp_p,   'largura': larg_p,
            'psd_fit': per_media[idx_p], 'densidade_fit': per_media[idx_p],
            'indice_freq': idx_p,
        })

    return {
        'freq_banda':                 freq_banda_ref,
        'psd_banda_micro':            psd_media,
        'full_fit_linear':            fit_media,
        'ap_fit_linear':              ap_media,
        'componente_periodica':       per_media,
        'fooof_model':                fm_medio,
        'picos':                      picos_medios,
        'picos_brutos':               todos_picos,
        'r_squared':                  fm_medio.r_squared_,
        'erro':                       fm_medio.error_,
        'n_intervalos':               n_usadas,
        'num_picos_total_intervalos': len(todos_picos),
        'metodo_media':               'geometrica_log',
    }


