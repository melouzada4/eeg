def calcular_media_metricas_graf(lista_resultados):
    """Alias mantido para compatibilidade — chama calcular_media_metricas."""
    return calcular_media_metricas(lista_resultados)


def salvar_resultados_completo(saida, arquivo, prefixo, nome_canal, nome_banda,
                               intervalos_oa, intervalos_of,
                               resultados_oa, resultados_of,
                               falhas_oa, falhas_of,
                               media_oa, media_of):
    txt_path = os.path.join(saida, f"{prefixo}_{nome_canal}_{nome_banda}_COMPLETO.txt")

    def _fmt(v, d=5):
        return f"{v:.{d}f}" if v is not None else "N/A"

    def bloco_media(titulo, media):
        if not media:
            return f"{titulo}: sem dados válidos\n"
        s  = f"{titulo} (n={media['num_intervalos_validos']}/10):\n"
        s += f"  ORIGINAL (potência padrão EEG):\n"
        s += f"    PSD={_fmt(media['psd_media_original'])}±{_fmt(media.get('psd_media_original_std',0))}  "
        s += f"Área={_fmt(media['area_original'])}±{_fmt(media.get('area_original_std',0))} µV²\n"
        s += f"  APERIÓDICA:\n"
        s += f"    PSD={_fmt(media['psd_media_aperiodic'])}±{_fmt(media.get('psd_media_aperiodic_std',0))}  "
        s += f"Área={_fmt(media['area_aperiodic'])}±{_fmt(media.get('area_aperiodic_std',0))} µV²\n"
        s += f"  PERIÓDICA (gaussianas FOOOF) [⚠ não é potência total]:\n"
        s += f"    PSD={_fmt(media['psd_media_fit'])}±{_fmt(media.get('psd_media_fit_std',0))}  "
        s += f"Área={_fmt(media['area_fit'])}±{_fmt(media.get('area_fit_std',0))} µV²\n"
        s += f"  R² médio: {_fmt(media['r_squared'],4)}±{_fmt(media.get('r_squared_std',0),4)}\n"

        # ── PICOS com DP (MODIFICAÇÃO 1) ────────────────────────────────────
        if media.get('num_picos_total', 0) > 0:
            freq_m   = media.get('frequencia_picos_media')
            freq_sd  = media.get('frequencia_picos_std')
            psd_m    = media.get('psd_fit_picos_media')
            psd_sd   = media.get('psd_fit_picos_std')
            freq_rng = (f"[{_fmt(media['frequencia_picos_min'],2)}–{_fmt(media['frequencia_picos_max'],2)} Hz]"
                        if media.get('frequencia_picos_min') is not None else "")
            s += (f"  PICOS ({media['num_picos_total']} total):\n"
                  f"    Freq. média: {_fmt(freq_m,3)} ± {_fmt(freq_sd,3)} Hz  {freq_rng}\n"
                  f"    PSD Pico média: {_fmt(psd_m)} ± {_fmt(psd_sd)} µV²/Hz\n")
        else:
            s += "  PICOS: Nenhum detectado\n"
        return s

    with open(txt_path, 'w', encoding='utf-8') as f:
        f.write(f"ANÁLISE FOOOF COMPLETA — {prefixo}\n")
        f.write(f"Arquivo: {arquivo}\nCanal: {nome_canal}\nBanda: {nome_banda.upper()}\n")
        f.write(f"FOOOF fit: {FOOOF_FMIN:.0f}-{FOOOF_FMAX:.0f} Hz  |  R² threshold: {R2_THRESHOLD}\n")
        f.write(f"Componente periódica: reconstruída via gaussianas (Donoghue et al., 2020)\n")
        f.write(f"Média entre intervalos: geométrica (log-espaço)\n{'='*80}\n\n")
        f.write("1. RESUMO — MÉDIAS DOS INTERVALOS:\n" + "-"*50 + "\n")
        f.write(bloco_media("OLHOS ABERTOS",  media_oa))
        f.write(bloco_media("OLHOS FECHADOS", media_of))
        f.write("\n" + "="*80 + "\n2. DETALHES POR INTERVALO:\n\n")

        for titulo, intervalos, resultados, falhas in [
            ("2.1 OLHOS ABERTOS",  intervalos_oa, resultados_oa, falhas_oa),
            ("2.2 OLHOS FECHADOS", intervalos_of, resultados_of, falhas_of),
        ]:
            f.write(f"{titulo}:\n" + "-"*50 + "\n")
            for i, (inicio, res, falha) in enumerate(zip(intervalos, resultados, falhas)):
                f.write(f"Intervalo {i+1}: {inicio}s-{inicio+6}s\n")
                if res:
                    # Picos com DP por intervalo (MODIFICAÇÃO 1)
                    picos_res = res.get('picos', [])
                    n_p = len(picos_res)
                    f.write(f"  ✔ VÁLIDO  R²={res['r_squared']:.4f}  Erro={res['erro']:.4f}  Picos={n_p}\n")
                    f.write(f"  ORIGINAL:     PSD={res['psd_media_original']:.5f}  Área={res['area_original']:.5f} µV²\n")
                    f.write(f"  APERIÓDICA:   PSD={res['psd_media_aperiodic']:.5f}  Área={res['area_aperiodic']:.5f} µV²\n")
                    f.write(f"  PERIÓDICA:    PSD={res['psd_media_fit']:.5f}  Área={res['area_fit']:.5f} µV²\n")
                    for j, p in enumerate(picos_res):
                        f.write(f"    Pico {j+1}: {p['frequencia']:.3f}Hz  PSD={p['psd_fit']:.5f} µV²/Hz\n")
                else:
                    f.write(f"  ✘ DESCARTADO — motivo: {falha}\n")
                f.write("\n")
        f.write("="*80)


def classificar_r2_bins(lista_resultados):
    bins = {'75-80': 0, '80-85': 0, '85-90': 0, '90-95': 0, '95-100': 0}
    for r in lista_resultados:
        if r is None: continue
        r2 = r.get('r_squared', 0)
        if   r2 < R2_THRESHOLD: continue
        elif r2 < 0.80: bins['75-80']  += 1
        elif r2 < 0.85: bins['80-85']  += 1
        elif r2 < 0.90: bins['85-90']  += 1
        elif r2 < 0.95: bins['90-95']  += 1
        else:           bins['95-100'] += 1
    return bins


def contar_validos(lista_resultados):
    validos = sum(1 for r in lista_resultados if r is not None and r.get('r_squared', 0) >= R2_THRESHOLD)
    total   = sum(1 for r in lista_resultados if r is not None)
    return validos, total


def salvar_r2_por_canal(prefixo, nome_canal, r2_dict, pasta_saida):
    caminho = os.path.join(pasta_saida, f"{prefixo}_{nome_canal}_R2_RESUMO.txt")
    with open(caminho, 'w', encoding='utf-8') as f:
        f.write(f"PACIENTE/ARQUIVO: {prefixo}\nCANAL: {nome_canal}\n"
                f"R² threshold: {R2_THRESHOLD}  |  FOOOF fit: {FOOOF_FMIN:.0f}-{FOOOF_FMAX:.0f} Hz\n{'='*60}\n\n")
        for banda in r2_dict:
            f.write(f"BANDA: {banda.upper()}\n" + "-"*40 + "\n")
            for cond in ['OA', 'OF']:
                f.write(f"{cond}:\n")
                for faixa, v in r2_dict[banda][cond].items():
                    f.write(f"  {faixa}: {v}\n")
            f.write("\n")
    print(f"      ✔ R² salvo: {prefixo}_{nome_canal}_R2_RESUMO.txt")


