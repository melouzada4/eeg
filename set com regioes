# ============================================================
# Detecção e normalização de unidade do sinal
# ============================================================

def detectar_unidade_canal(raw):
    try:
        from mne.io.constants import FIFF
        eeg_chs = [ch for ch in raw.info['chs'] if ch['kind'] == FIFF.FIFFV_EEG_CH]
        if eeg_chs:
            unit_code = eeg_chs[0]['unit']
            if unit_code == FIFF.FIFF_UNIT_V:
                print("  [Unidade] Campo FIFF indica Volts → convertendo para µV (×1e6)")
                return False
            else:
                print(f"  [Unidade] Campo FIFF unit={unit_code} → assumindo µV (sem conversão)")
                return True
    except Exception:
        pass

    amostra = raw.get_data(start=0, stop=min(2000, raw.n_times))
    std_val = np.median(np.std(amostra, axis=1))
    if std_val < 1e-3:
        print(f"  [Unidade] Amplitude típica={std_val:.2e} → detectado Volts → convertendo para µV (×1e6)")
        return False
    else:
        print(f"  [Unidade] Amplitude típica={std_val:.2e} → detectado µV (sem conversão)")
        return True


