def calcular_media_fooof_para_grafico(lista_metricas):
    metricas_validas = [m for m in lista_metricas if m is not None]
    if not metricas_validas:
        return None

    freq_banda_ref = metricas_validas[0]['freq_banda']
    n_freq         = len(freq_banda_ref)

    psd_soma = np.zeros(n_freq)
    fit_soma = np.zeros(n_freq)
    ap_soma  = np.zeros(n_freq)
    per_soma = np.zeros(n_freq)
    n_usadas = 0
    todos_picos = []

    for m in metricas_validas:
        arrays = [m['psd_banda_micro'], m['full_fit_linear'], m['ap_fit_linear'], m['componente_periodica']]
        if any(np.any(np.isnan(a)) or np.any(np.isinf(a)) for a in arrays):
            print("      Aviso: intervalo ignorado na média do gráfico (NaN/Inf)")
            continue
        if len(m['freq_banda']) == n_freq and np.allclose(m['freq_banda'], freq_banda_ref):
            psd_soma += m['psd_banda_micro']
            fit_soma += m['full_fit_linear']
            ap_soma  += m['ap_fit_linear']
            per_soma += m['componente_periodica']
            todos_picos.extend(m.get('picos', []))
            n_usadas += 1

    if n_usadas == 0:
        return None

    per_media = per_soma / n_usadas

    class FooofMedio:
        def __init__(self):
            self.r_squared_   = np.mean([m['r_squared'] for m in metricas_validas])
            self.error_       = np.mean([m['erro']       for m in metricas_validas])
            self.peak_params_ = []
            if todos_picos:
                grupos = []
                for p in todos_picos:
                    adicionado = False
                    for g in grupos:
                        if abs(p['frequencia'] - g[0]['frequencia']) <= 1.0:
                            g.append(p); adicionado = True; break
                    if not adicionado:
                        grupos.append([p])
                for g in grupos:
                    self.peak_params_.append([
                        np.mean([p['frequencia'] for p in g]),
                        np.mean([p['amplitude']  for p in g]),
                        np.mean([p['largura']    for p in g]),
                    ])

    fm_medio     = FooofMedio()
    picos_medios = []
    for freq_p, amp_p, larg_p in fm_medio.peak_params_:
        idx_p = np.argmin(np.abs(freq_banda_ref - freq_p))
        picos_medios.append({
            'frequencia': freq_p, 'frequencia_fooof': freq_p,
            'amplitude': amp_p,   'largura': larg_p,
            'psd_fit': per_media[idx_p], 'densidade_fit': per_media[idx_p],
            'indice_freq': idx_p,
        })

    return {
        'freq_banda':                 freq_banda_ref,
        'psd_banda_micro':            psd_soma / n_usadas,
        'full_fit_linear':            fit_soma / n_usadas,
        'ap_fit_linear':              ap_soma  / n_usadas,
        'componente_periodica':       per_media,
        'fooof_model':                fm_medio,
        'picos':                      picos_medios,
        'picos_brutos':               todos_picos,
        'r_squared':                  fm_medio.r_squared_,
        'erro':                       fm_medio.error_,
        'n_intervalos':               n_usadas,
        'num_picos_total_intervalos': len(todos_picos),
    }


def criar_grafico_fooof_com_stats(resultado, nome_banda, nome_canal, prefixo_arquivo,
                                  fmin, fmax, pasta_saida, condicao):
    try:
        freq_banda           = resultado['freq_banda']
        psd_banda_micro      = resultado['psd_banda_micro']
        full_fit_linear      = resultado['full_fit_linear']
        ap_fit_linear        = resultado['ap_fit_linear']
        componente_periodica = resultado.get('componente_periodica', full_fit_linear - ap_fit_linear)

        plt.figure(figsize=(14, 8))
        plt.style.use('default')

        plt.plot(freq_banda, psd_banda_micro, color='#000000', linewidth=1.5, alpha=0.8, label='Espectro Original')
        plt.plot(freq_banda, full_fit_linear, color='#e74c3c', linewidth=2,              label='Modelo Completo FOOOF')
        plt.plot(freq_banda, ap_fit_linear,   color='#3498db', linewidth=2, linestyle='--', label='Componente Aperiódica')
        plt.fill_between(freq_banda, ap_fit_linear, full_fit_linear, color='lightgreen', alpha=0.3, label='Componente Periódica')

        cond_nome = 'Olhos Abertos' if condicao == 'OA' else 'Olhos Fechados'
        n_int_str = f" (Média de {resultado['n_intervalos']} intervalos)" if 'n_intervalos' in resultado else ""
        plt.title(f"Banda {nome_banda.upper()} — Canal {nome_canal} — {cond_nome} — "
                  f"{prefixo_arquivo}{n_int_str} [FOOOF {FOOOF_FMIN:.0f}-{FOOOF_FMAX:.0f} Hz]",
                  fontsize=12, fontweight='bold')
        plt.xlabel('Frequência (Hz)', fontsize=12, fontweight='bold')
        plt.ylabel('Densidade Espectral de Potência (µV²/Hz)', fontsize=12, fontweight='bold')

        handles = [
            plt.Line2D([0],[0], color='#000000', linewidth=1.5,                label='Original Spectrum'),
            plt.Line2D([0],[0], color='#e74c3c', linewidth=2,                 label='Full FOOOF Model'),
            plt.Line2D([0],[0], color='#3498db', linewidth=2, linestyle='--', label='Aperiodic Component'),
            plt.Line2D([0],[0], color='#2ecc71', linewidth=2,                 label='Periodic Component (FIT)'),
        ]
        legend = plt.legend(handles=handles, loc='center right', bbox_to_anchor=(0.99, 0.5),
                            fontsize=9, frameon=True, fancybox=True, shadow=True, framealpha=0.9)
        legend.get_frame().set_facecolor('white')
        legend.get_frame().set_edgecolor('black')
        plt.grid(True, linestyle='--', linewidth=0.5, alpha=0.3, color='gray')

        ax           = plt.gca()
        psd_med_per  = np.mean(componente_periodica)
        area_per     = np.trapezoid(componente_periodica, freq_banda)
        picos_brutos = resultado.get('picos_brutos', resultado.get('picos', []))
        n_picos      = len(picos_brutos)

        stats_text = (
            f"Estatísticas {nome_banda.upper()} ({fmin:.1f}-{fmax} Hz):\n"
            f"[FOOOF fit: {FOOOF_FMIN:.0f}-{FOOOF_FMAX:.0f} Hz]\n\n"
            f"ORIGINAL:\nPSD Média: {np.mean(psd_banda_micro):.4f} µV²/Hz\n"
            f"Área Total: {np.trapezoid(psd_banda_micro, freq_banda):.4f} µV²\n\n"
            f"APERIÓDICA:\nPSD Média: {np.mean(ap_fit_linear):.4f} µV²/Hz\n"
            f"Área Total: {np.trapezoid(ap_fit_linear, freq_banda):.4f} µV²\n\n"
            f"FIT (PERIÓDICA):\nPSD Média: {psd_med_per:.4f} µV²/Hz\n"
            f"Área Total: {area_per:.4f} µV²\n\n"
        )
        if picos_brutos:
            stats_text += (f"Picos ({n_picos}):\n"
                           f"Freq. Média: {np.mean([p['frequencia'] for p in picos_brutos]):.2f} Hz\n"
                           f"PSD Média: {np.mean([p['psd_fit'] for p in picos_brutos]):.4f} µV²/Hz")
        else:
            stats_text += "Picos: Nenhum detectado"

        plt.text(0.98, 0.98, stats_text, transform=ax.transAxes, fontsize=8,
                 verticalalignment='top', horizontalalignment='right',
                 bbox=dict(boxstyle='round,pad=0.5', facecolor='white', edgecolor='black', alpha=0.9))
        plt.text(0.02, 0.02,
                 f"FOOOF ({FOOOF_FMIN:.0f}-{FOOOF_FMAX:.0f} Hz):\nR²: {resultado.get('r_squared',0):.4f}\nPicos: {n_picos}",
                 transform=ax.transAxes, fontsize=9, verticalalignment='bottom', horizontalalignment='left',
                 bbox=dict(boxstyle='round,pad=0.4', facecolor='lightblue', edgecolor='black', alpha=0.9))

        plt.tight_layout()
        sufixo    = "_MEDIA" if 'n_intervalos' in resultado else ""
        nome_graf = f"{prefixo_arquivo}_{nome_canal}_{nome_banda}_{condicao}_FOOOF{sufixo}.png"
        plt.savefig(os.path.join(pasta_saida, nome_graf), dpi=300, bbox_inches='tight',
                    facecolor='white', edgecolor='none')
        plt.close()
        print(f"        Gráfico salvo: {nome_graf}")

    except Exception as e:
        print(f"        Erro ao criar gráfico: {e}")
        plt.close()


def calcular_media_metricas(lista_resultados):
    validos = [r for r in lista_resultados if r is not None]
    if not validos:
        return None

    n      = len(validos)
    campos = ['psd_media_original','area_original','psd_media_aperiodic',
              'area_aperiodic','psd_media_fit','area_fit','r_squared','erro']
    soma   = {c: 0   for c in campos}
    listas = {c: []  for c in campos}
    todos_picos = []

    for r in validos:
        for c in campos:
            soma[c] += r[c]; listas[c].append(r[c])
        todos_picos.extend(r.get('picos', []))

    media = {
        'num_intervalos_validos': n,
        **{c: soma[c]/n            for c in campos},
        **{f'{c}_std': np.std(listas[c]) for c in campos},
    }
    if todos_picos:
        media.update({
            'num_picos_total':        len(todos_picos),
            'frequencia_picos_media': np.mean([p['frequencia'] for p in todos_picos]),
            'psd_fit_picos_media':    np.mean([p['psd_fit']    for p in todos_picos]),
        })
    return media


def salvar_resultados_completo(saida, arquivo, prefixo, nome_canal, nome_banda,
                               intervalos_oa, intervalos_of,
                               resultados_oa, resultados_of,
                               falhas_oa, falhas_of,
                               media_oa, media_of):
    txt_path = os.path.join(saida, f"{prefixo}_{nome_canal}_{nome_banda}_COMPLETO.txt")

    def bloco_media(titulo, media):
        if not media:
            return f"{titulo}: sem dados válidos\n"
        s  = f"{titulo} (n={media['num_intervalos_validos']}/10):\n"
        s += f"  ORIGINAL:    PSD={media['psd_media_original']:.5f}±{media.get('psd_media_original_std',0):.5f}  Área={media['area_original']:.5f}±{media.get('area_original_std',0):.5f} µV²\n"
        s += f"  APERIÓDICA:  PSD={media['psd_media_aperiodic']:.5f}±{media.get('psd_media_aperiodic_std',0):.5f}  Área={media['area_aperiodic']:.5f}±{media.get('area_aperiodic_std',0):.5f} µV²\n"
        s += f"  FIT/PERIÓD.: PSD={media['psd_media_fit']:.5f}±{media.get('psd_media_fit_std',0):.5f}  Área={media['area_fit']:.5f}±{media.get('area_fit_std',0):.5f} µV²\n"
        s += f"  R² médio: {media['r_squared']:.4f}±{media.get('r_squared_std',0):.4f}\n"
        if 'frequencia_picos_media' in media:
            s += f"  Picos: {media['num_picos_total']} total | freq média: {media['frequencia_picos_media']:.2f}Hz | PSD Fit média: {media['psd_fit_picos_media']:.5f} µV²/Hz\n"
        return s

    with open(txt_path, 'w', encoding='utf-8') as f:
        f.write(f"ANÁLISE FOOOF COMPLETA — {prefixo}\n")
        f.write(f"Arquivo: {arquivo}\nCanal: {nome_canal}\nBanda: {nome_banda.upper()}\n")
        f.write(f"FOOOF fit: {FOOOF_FMIN:.0f}-{FOOOF_FMAX:.0f} Hz  |  R² threshold: {R2_THRESHOLD}\n{'='*80}\n\n")
        f.write("1. RESUMO — MÉDIAS DOS INTERVALOS:\n" + "-"*50 + "\n")
        f.write(bloco_media("OLHOS ABERTOS",  media_oa))
        f.write(bloco_media("OLHOS FECHADOS", media_of))
        f.write("\n" + "="*80 + "\n2. DETALHES POR INTERVALO:\n\n")

        for titulo, intervalos, resultados, falhas in [
            ("2.1 OLHOS ABERTOS",  intervalos_oa, resultados_oa, falhas_oa),
            ("2.2 OLHOS FECHADOS", intervalos_of, resultados_of, falhas_of),
        ]:
            f.write(f"{titulo}:\n" + "-"*50 + "\n")
            for i, (inicio, res, falha) in enumerate(zip(intervalos, resultados, falhas)):
                f.write(f"Intervalo {i+1}: {inicio}s-{inicio+6}s\n")
                if res:
                    f.write(f"  ✔ VÁLIDO  R²={res['r_squared']:.4f}  Erro={res['erro']:.4f}  Picos={len(res['picos'])}\n")
                    f.write(f"  ORIGINAL:     PSD={res['psd_media_original']:.5f}  Área={res['area_original']:.5f} µV²\n")
                    f.write(f"  APERIÓDICA:   PSD={res['psd_media_aperiodic']:.5f}  Área={res['area_aperiodic']:.5f} µV²\n")
                    f.write(f"  FIT/PERIÓD.:  PSD={res['psd_media_fit']:.5f}  Área={res['area_fit']:.5f} µV²\n")
                    for j, p in enumerate(res['picos']):
                        f.write(f"    Pico {j+1}: {p['frequencia']:.2f}Hz  PSD={p['psd_fit']:.5f} µV²/Hz\n")
                else:
                    f.write(f"  ✘ DESCARTADO — motivo: {falha}\n")
                f.write("\n")
        f.write("="*80)


def classificar_r2_bins(lista_resultados):
    bins = {'75-80': 0, '80-85': 0, '85-90': 0, '90-95': 0, '95-100': 0}
    for r in lista_resultados:
        if r is None: continue
        r2 = r.get('r_squared', 0)
        if   r2 < R2_THRESHOLD: continue
        elif r2 < 0.80: bins['75-80']  += 1
        elif r2 < 0.85: bins['80-85']  += 1
        elif r2 < 0.90: bins['85-90']  += 1
        elif r2 < 0.95: bins['90-95']  += 1
        else:           bins['95-100'] += 1
    return bins


def contar_validos(lista_resultados):
    validos = sum(1 for r in lista_resultados if r is not None and r.get('r_squared', 0) >= R2_THRESHOLD)
    total   = sum(1 for r in lista_resultados if r is not None)
    return validos, total


def salvar_r2_por_canal(prefixo, nome_canal, r2_dict, pasta_saida):
    caminho = os.path.join(pasta_saida, f"{prefixo}_{nome_canal}_R2_RESUMO.txt")
    with open(caminho, 'w', encoding='utf-8') as f:
        f.write(f"PACIENTE/ARQUIVO: {prefixo}\nCANAL: {nome_canal}\n"
                f"R² threshold: {R2_THRESHOLD}  |  FOOOF fit: {FOOOF_FMIN:.0f}-{FOOOF_FMAX:.0f} Hz\n{'='*60}\n\n")
        for banda in r2_dict:
            f.write(f"BANDA: {banda.upper()}\n" + "-"*40 + "\n")
            for cond in ['OA', 'OF']:
                f.write(f"{cond}:\n")
                for faixa, v in r2_dict[banda][cond].items():
                    f.write(f"  {faixa}: {v}\n")
            f.write("\n")
    print(f"      ✔ R² salvo: {prefixo}_{nome_canal}_R2_RESUMO.txt")


