def carregar_intervalos_planilha(caminho_planilha):
    try:
        df = pd.read_excel(caminho_planilha)
        intervalos_pacientes = {}

        print("Estrutura da planilha:")
        print(f"Colunas: {list(df.columns)}")
        print(f"Primeiras linhas:\n{df.head()}")

        for idx, row in df.iterrows():
            nome_original = str(row.iloc[0]).strip()
            chave = extrair_prefixo(nome_original)

            olhos_abertos  = [int(row.iloc[i]) for i in range(1, 11)  if i < len(row) and not pd.isna(row.iloc[i])]
            olhos_fechados = [int(row.iloc[i]) for i in range(11, 21) if i < len(row) and not pd.isna(row.iloc[i])]

            if len(olhos_abertos) >= 10 and len(olhos_fechados) >= 10:
                intervalos_pacientes[chave] = {
                    'olhos_abertos':  olhos_abertos[:10],
                    'olhos_fechados': olhos_fechados[:10],
                    'nome_original':  nome_original,
                }
                print(f"  Carregado [{chave}] ('{nome_original}'): OA={olhos_abertos[:3]}... OF={olhos_fechados[:3]}...")
            else:
                print(f"  Aviso: [{chave}] — OA:{len(olhos_abertos)}, OF:{len(olhos_fechados)} intervalos")

        return intervalos_pacientes

    except Exception as e:
        print(f"Erro ao carregar planilha: {e}")
        return {}


