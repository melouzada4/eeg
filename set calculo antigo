def processar_paciente(arquivo_set, intervalos_pacientes, saida):
    arquivo = os.path.basename(arquivo_set)
    prefixo = extrair_prefixo(arquivo)

    intervalos_paciente = intervalos_pacientes.get(prefixo)
    if not intervalos_paciente:
        print(f"\n❌ Prefixo '{prefixo}' não encontrado na planilha.")
        print(f"   Prefixos disponíveis: {list(intervalos_pacientes.keys())}")
        return []

    print(f"\n✔ Arquivo  : {arquivo}")
    print(f"  Prefixo  : {prefixo}")
    print(f"  Planilha : '{intervalos_paciente['nome_original']}'")
    print(f"  R² threshold: {R2_THRESHOLD}  |  Mínimo intervalos válidos: {MIN_INTERVALOS_VALIDOS}")

    resumo_validos = []
    todas_falhas   = defaultdict(lambda: defaultdict(lambda: defaultdict(list)))

    try:
        raw             = mne.io.read_raw_eeglab(arquivo_set, preload=True)
        dados_completos = raw.get_data()
        srate           = int(raw.info['sfreq'])
        canais          = raw.info['ch_names']
        duracao_total   = dados_completos.shape[1] / srate

        print(f"  Duração: {duracao_total:.2f}s | Canais: {len(canais)} | Taxa: {srate}Hz")

        for i, nome_canal in enumerate(canais):
            r2_acumulado_canal = {}
            print(f"  Canal: {nome_canal}")

            if np.all(dados_completos[i, :] == 0):
                print("    Canal zerado — pulando")
                continue

            for nome_banda, (fmin, fmax) in bandas.items():
                resultados_oa, falhas_oa = [], []
                resultados_of, falhas_of = [], []

                for inicio in intervalos_paciente['olhos_abertos']:
                    if inicio + DURACAO_INTERVALO <= duracao_total:
                        seg = extrair_segmento_temporal(dados_completos, srate, inicio, DURACAO_INTERVALO)
                        res, motivo = calcular_metricas_fooof_segmento(seg[i, :], srate, nome_banda, fmin, fmax)
                        resultados_oa.append(res)
                        falhas_oa.append((inicio, motivo))
                        todas_falhas[nome_canal][nome_banda]['OA'].append((inicio, motivo))
                    else:
                        resultados_oa.append(None)
                        falhas_oa.append((inicio, f"intervalo {inicio}s excede duração do arquivo"))
                        todas_falhas[nome_canal][nome_banda]['OA'].append((inicio, f"excede duração"))

                for inicio in intervalos_paciente['olhos_fechados']:
                    if inicio + DURACAO_INTERVALO <= duracao_total:
                        seg = extrair_segmento_temporal(dados_completos, srate, inicio, DURACAO_INTERVALO)
                        res, motivo = calcular_metricas_fooof_segmento(seg[i, :], srate, nome_banda, fmin, fmax)
                        resultados_of.append(res)
                        falhas_of.append((inicio, motivo))
                        todas_falhas[nome_canal][nome_banda]['OF'].append((inicio, motivo))
                    else:
                        resultados_of.append(None)
                        falhas_of.append((inicio, f"excede duração"))
                        todas_falhas[nome_canal][nome_banda]['OF'].append((inicio, f"excede duração"))

                media_oa = calcular_media_metricas(resultados_oa)
                media_of = calcular_media_metricas(resultados_of)

                validos_oa, total_oa = contar_validos(resultados_oa)
                validos_of, total_of = contar_validos(resultados_of)

                # Aviso se abaixo do mínimo
                flag_oa = " ⚠ ABAIXO DO MÍNIMO" if validos_oa < MIN_INTERVALOS_VALIDOS else ""
                flag_of = " ⚠ ABAIXO DO MÍNIMO" if validos_of < MIN_INTERVALOS_VALIDOS else ""
                print(f"    {nome_banda.upper()}: OA={validos_oa}/{total_oa}{flag_oa}  OF={validos_of}/{total_of}{flag_of}")

                resumo_validos += [
                    {'paciente': prefixo, 'canal': nome_canal, 'banda': nome_banda,
                     'condicao': 'OA', 'validos': validos_oa, 'total': total_oa,
                     'abaixo_minimo': validos_oa < MIN_INTERVALOS_VALIDOS},
                    {'paciente': prefixo, 'canal': nome_canal, 'banda': nome_banda,
                     'condicao': 'OF', 'validos': validos_of, 'total': total_of,
                     'abaixo_minimo': validos_of < MIN_INTERVALOS_VALIDOS},
                ]

                r2_acumulado_canal[nome_banda] = {
                    'OA': classificar_r2_bins(resultados_oa),
                    'OF': classificar_r2_bins(resultados_of),
                }

                salvar_resultados_completo(
                    saida, arquivo, prefixo, nome_canal, nome_banda,
                    intervalos_paciente['olhos_abertos'],
                    intervalos_paciente['olhos_fechados'],
                    resultados_oa, resultados_of,
                    falhas_oa, falhas_of,
                    media_oa, media_of
                )
                salvar_r2_por_canal(prefixo, nome_canal, r2_acumulado_canal, saida)

                for condicao, resultados, media in [('OA', resultados_oa, media_oa), ('OF', resultados_of, media_of)]:
                    if media is not None and media['num_intervalos_validos'] >= MIN_INTERVALOS_VALIDOS:
                        dados_graf = calcular_media_fooof_para_grafico(resultados)
                        if dados_graf:
                            criar_grafico_fooof_com_stats(
                                dados_graf, nome_banda, nome_canal,
                                prefixo, fmin, fmax, saida, condicao
                            )

    except Exception as e:
        print(f"Erro ao processar {arquivo}: {e}")
        import traceback
        traceback.print_exc()

    # Salva diagnóstico consolidado de todas as falhas
    salvar_diagnostico_falhas(prefixo, todas_falhas, saida)

    return resumo_validos


