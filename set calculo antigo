def salvar_diagnostico_falhas(prefixo, todas_falhas, pasta_saida):
    """
    todas_falhas: dict  canal -> banda -> condicao -> [(inicio_s, motivo), ...]
    Gera um arquivo de diagnóstico resumindo por que cada segmento foi descartado.
    """
    caminho = os.path.join(pasta_saida, f"{prefixo}_DIAGNOSTICO_FALHAS.txt")

    # Conta frequência de cada motivo
    contador_motivos = defaultdict(int)
    for canal in todas_falhas:
        for banda in todas_falhas[canal]:
            for cond in todas_falhas[canal][banda]:
                for _, motivo in todas_falhas[canal][banda][cond]:
                    if motivo:
                        # Agrupa motivos de R² por faixa
                        if motivo.startswith("R²="):
                            r2_val = float(motivo.split("=")[1].split(" ")[0])
                            if r2_val < 0.50:   contador_motivos["R² < 0.50 (fit muito ruim)"] += 1
                            elif r2_val < 0.65: contador_motivos["R² 0.50–0.65 (fit ruim)"]    += 1
                            elif r2_val < R2_THRESHOLD: contador_motivos[f"R² 0.65–{R2_THRESHOLD} (abaixo do threshold)"] += 1
                        else:
                            contador_motivos[motivo] += 1

    with open(caminho, 'w', encoding='utf-8') as f:
        f.write(f"DIAGNÓSTICO DE FALHAS — {prefixo}\n")
        f.write(f"R² threshold usado: {R2_THRESHOLD}  |  Mínimo de intervalos válidos: {MIN_INTERVALOS_VALIDOS}\n")
        f.write("="*80 + "\n\n")

        f.write("1. RESUMO GERAL DE MOTIVOS DE DESCARTE:\n" + "-"*50 + "\n")
        if contador_motivos:
            total_falhas = sum(contador_motivos.values())
            for motivo, count in sorted(contador_motivos.items(), key=lambda x: -x[1]):
                f.write(f"  {count:4d}x  ({100*count/total_falhas:.1f}%)  →  {motivo}\n")
        else:
            f.write("  Nenhuma falha registrada.\n")
        f.write("\n")

        f.write("2. CANAIS/BANDAS COM MENOS DE "
                f"{MIN_INTERVALOS_VALIDOS} INTERVALOS VÁLIDOS:\n" + "-"*50 + "\n")
        encontrou = False
        for canal in sorted(todas_falhas):
            for banda in sorted(todas_falhas[canal]):
                for cond in ['OA', 'OF']:
                    falhas_cond = todas_falhas[canal][banda].get(cond, [])
                    n_falhas    = sum(1 for _, m in falhas_cond if m is not None)
                    n_validos   = sum(1 for _, m in falhas_cond if m is None)
                    if n_validos < MIN_INTERVALOS_VALIDOS:
                        encontrou = True
                        cond_nome = "Olhos Abertos" if cond == "OA" else "Olhos Fechados"
                        motivos_cond = [m for _, m in falhas_cond if m]
                        resumo_motivos = {}
                        for m in motivos_cond:
                            chave_m = m.split(" abaixo")[0].split("=")[0] if "R²" in m else m[:40]
                            resumo_motivos[chave_m] = resumo_motivos.get(chave_m, 0) + 1
                        resumo_str = "  |  ".join(f"{k}: {v}x" for k,v in resumo_motivos.items())
                        f.write(f"  {canal} | {banda.upper()} | {cond_nome}: "
                                f"{n_validos}/10 válidos — {resumo_str}\n")
        if not encontrou:
            f.write("  Todos os canais/bandas têm intervalos suficientes.\n")

        f.write("\n" + "="*80 + "\n")
        f.write("3. DETALHE COMPLETO POR CANAL:\n\n")
        for canal in sorted(todas_falhas):
            f.write(f"  CANAL: {canal}\n")
            for banda in sorted(todas_falhas[canal]):
                for cond in ['OA', 'OF']:
                    falhas_cond = todas_falhas[canal][banda].get(cond, [])
                    if not falhas_cond:
                        continue
                    cond_nome = "OA" if cond == "OA" else "OF"
                    n_val = sum(1 for _, m in falhas_cond if m is None)
                    f.write(f"    {banda.upper()} {cond_nome} ({n_val}/10 válidos):\n")
                    for inicio, motivo in falhas_cond:
                        status = "✔" if motivo is None else f"✘ {motivo}"
                        f.write(f"      {inicio}s: {status}\n")
            f.write("\n")

    print(f"\n  📋 Diagnóstico salvo: {prefixo}_DIAGNOSTICO_FALHAS.txt")
    print(f"     Motivos principais:")
    for motivo, count in sorted(contador_motivos.items(), key=lambda x: -x[1])[:5]:
        print(f"       {count}x → {motivo}")


